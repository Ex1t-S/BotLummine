{
  "name": "whatsapp-ai-assistant-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:prod": "node src/server.js",
    "jobs:enbox-sync": "node src/jobs/enbox-sync.job.js",
    "jobs:campaign-dispatch": "node src/jobs/campaign-dispatch.job.js",
    "jobs:diagnose": "node src/jobs/diagnose.job.js",
    "ai:test:no-context": "node scripts/test-ai-no-context.mjs",
    "ai:test:workspace-flow": "node scripts/test-ai-workspace-flow.mjs",
    "ai:profile-isolation": "node scripts/test-ai-profile-isolation.mjs",
    "ai:regression": "node scripts/run-ai-regression-suite.mjs",
    "ai:regression:compare": "node scripts/compare-ai-regression-suite.mjs",
    "catalog:fuzzy-test": "node scripts/test-catalog-fuzzy-search.mjs",
    "ai:campaign-qa": "node scripts/run-ai-campaign-qa.mjs",
    "ai:campaign-qa:smoke": "node scripts/run-ai-campaign-qa.mjs --smoke",
    "ai:campaign-qa:offline": "node scripts/run-ai-campaign-offline-qa.mjs",
    "audit:security": "npm audit --audit-level=high",
    "raw-payloads:compact:dry-run": "node scripts/compact-raw-payloads.mjs",
    "raw-payloads:compact:apply": "node scripts/compact-raw-payloads.mjs --apply",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "demo:showcase": "node prisma/seed-showcase-demo.mjs",
    "tiendanube:customers:debug": "node scripts/debug-tiendanube-customers.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.53.1",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.2",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "openai": "^6.39.1",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
