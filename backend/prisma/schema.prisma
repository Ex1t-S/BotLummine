generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  status    WorkspaceStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  users               User[]
  branding            WorkspaceBranding?
  aiConfig            WorkspaceAiConfig?
  commerceConnections CommerceConnection[]
  logisticsConnections LogisticsConnection[]
  whatsappChannels    WhatsAppChannel[]
  contacts            Contact[]
  conversations       Conversation[]
  aiLabRuns           AiLabRun[]
  menuSettings        WhatsAppMenuSetting[]
  messages            Message[]
  storeInstallations  StoreInstallation[]
  catalogProducts     CatalogProduct[]
  catalogSyncLogs     CatalogSyncLog[]
  abandonedCarts      AbandonedCart[]
  customerProfiles    CustomerProfile[]
  customerOrders      CustomerOrder[]
  customerOrderItems  CustomerOrderItem[]
  customerSyncLogs    CustomerSyncLog[]
  enboxShipments      EnboxShipment[]
  enboxSyncLogs       EnboxSyncLog[]
  whatsAppTemplates   WhatsAppTemplate[]
  templateSyncLogs    TemplateSyncLog[]
  campaigns           Campaign[]
  campaignRecipients  CampaignRecipient[]
  campaignConversions CampaignConversion[]
}

model WorkspaceBranding {
  id                  String    @id @default(cuid())
  workspaceId         String    @unique
  logoUrl             String?
  primaryColor        String?
  secondaryColor      String?
  accentColor         String?
  rawProviderBranding Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkspaceAiConfig {
  id              String   @id @default(cuid())
  workspaceId     String   @unique
  businessName    String
  agentName       String   @default("Sofi")
  tone            String   @default("humana, directa y comercial")
  systemPrompt    String?
  businessContext String?
  paymentConfig   Json?
  policyConfig    Json?
  catalogConfig   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CommerceConnection {
  id              String             @id @default(cuid())
  workspaceId     String
  provider        CommerceProvider
  externalStoreId String
  shopDomain      String?
  accessToken     String
  refreshToken    String?
  scope           String?
  status          ConnectionStatus   @default(ACTIVE)
  storeName       String?
  storeUrl        String?
  rawPayload      Json?
  installedAt     DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@unique([provider, externalStoreId])
  @@index([workspaceId, status])
}

model LogisticsConnection {
  id          String             @id @default(cuid())
  workspaceId String
  provider    LogisticsProvider
  username    String
  password    String
  status      ConnectionStatus   @default(ACTIVE)
  config      Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@index([workspaceId, status])
}

model WhatsAppChannel {
  id                 String           @id @default(cuid())
  workspaceId        String
  name               String           @default("Canal principal")
  wabaId             String
  phoneNumberId      String           @unique
  displayPhoneNumber String?
  accessToken        String
  verifyToken        String?
  graphVersion       String?
  status             ConnectionStatus @default(ACTIVE)
  rawPayload         Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([wabaId])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("AGENT")
  workspaceId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, role])
}

model Contact {
  id                    String    @id @default(cuid())
  workspaceId           String
  waId                  String
  phone                 String?
  name                  String?
  marketingOptIn        Boolean   @default(true)
  marketingOptedOutAt   DateTime?
  marketingOptOutReason String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([workspaceId, waId])
  @@index([workspaceId, updatedAt])
}

model Conversation {
  id            String             @id @default(cuid())
  workspaceId   String
  contactId     String
  status        ConversationStatus @default(OPEN)
  queue         ConversationQueue  @default(AUTO)
  aiEnabled     Boolean            @default(true)
  lastSummary   String?
  lastMessageAt DateTime?
  lastInboundMessageAt DateTime?
  lastReadAt    DateTime?
  unreadCount   Int                @default(0)
  archivedAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact  Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  state    ConversationState?
  messages Message[]
  aiLabRuns AiLabRun[]

  @@unique([workspaceId, contactId])
  @@index([workspaceId, lastMessageAt])
  @@index([workspaceId, unreadCount, lastMessageAt])
  @@index([workspaceId, archivedAt, lastMessageAt])
  @@index([workspaceId, queue, aiEnabled, lastMessageAt])
}

model AiLabRun {
  id              String   @id @default(cuid())
  workspaceId     String
  sessionId       String
  fixtureKey      String
  conversationId  String
  action          String?
  selectionId     String?
  userMessage     String?
  assistantMessage String?
  intent          String?
  provider        String?
  model           String?
  tracePayload    Json?
  createdAt       DateTime @default(now())

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([workspaceId, sessionId, createdAt])
  @@index([workspaceId, conversationId, createdAt])
  @@index([workspaceId, fixtureKey, createdAt])
}

model ConversationState {
  id                     String    @id @default(cuid())
  conversationId         String    @unique
  customerName           String?
  lastIntent             String?
  lastDetectedIntent     String?
  lastUserGoal           String?
  lastOrderNumber        String?
  lastOrderId            String?
  preferredTone          String?
  customerMood           String?
  urgencyLevel           String?
  frequentSize           String?
  paymentPreference      String?
  deliveryPreference     String?
  interestedProducts     Json?
  objections             Json?
  needsHuman             Boolean   @default(false)
  handoffReason          String?
  interactionCount       Int       @default(0)
  notes                  String?
  currentProductFocus    String?
  currentProductFamily   String?
  requestedOfferType     String?
  excludedProductKeywords Json?
  categoryLocked         Boolean   @default(false)
  salesStage             String?
  shownOffers            Json?
  shownPrices            Json?
  sharedLinks            Json?
  lastRecommendedProduct String?
  lastRecommendedOffer   String?
  buyingIntentLevel      String?
  frictionLevel          String?
  commercialSummary      String?
  menuActive             Boolean   @default(false)
  menuPath               String?
  menuLastSelection      String?
  menuLastPromptAt       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model WhatsAppMenuSetting {
  id        String   @id @default(cuid())
  workspaceId String
  key       String
  name      String   @default("Configuración principal")
  isActive  Boolean  @default(true)
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([workspaceId, isActive])
}

model Message {
  id                 String           @id @default(cuid())
  workspaceId        String
  conversationId     String
  metaMessageId      String?
  senderName         String?
  direction          MessageDirection
  type               String           @default("text")
  body               String
  provider           String?
  model              String?
  tokenPrompt        Int?
  tokenCompletion    Int?
  tokenTotal         Int?
  attachmentUrl      String?
  attachmentMimeType String?
  attachmentName     String?
  rawPayload         Json?
  createdAt          DateTime         @default(now())

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, metaMessageId])
  @@index([workspaceId, conversationId, createdAt])
  @@index([workspaceId, createdAt])
}

model StoreInstallation {
  id          String   @id @default(cuid())
  workspaceId String
  provider    CommerceProvider @default(TIENDANUBE)
  storeId     String   @unique
  accessToken String
  scope       String?
  storeName   String?
  storeUrl    String?
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider])
}

model CatalogProduct {
  id             String   @id @default(cuid())
  workspaceId    String
  provider       CommerceProvider @default(TIENDANUBE)
  storeId        String
  productId      String
  name           String
  handle         String?
  description    String?
  brand          String?
  price          Decimal? @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  published      Boolean  @default(true)
  tags           String?
  featuredImage  String?
  productUrl     String?
  variants       Json?
  images         Json?
  categories     Json?
  attributes     Json?
  rawPayload     Json?
  syncedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider, productId])
  @@index([workspaceId, storeId, published])
  @@index([workspaceId, name])
}

model CatalogSyncLog {
  id                String    @id @default(cuid())
  workspaceId       String
  provider          CommerceProvider @default(TIENDANUBE)
  storeId           String?
  status            String
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?
  productsProcessed Int       @default(0)
  message           String?
  createdAt         DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, provider, startedAt])
}

model AbandonedCart {
  id                   String    @id @default(cuid())
  workspaceId          String
  provider             CommerceProvider @default(TIENDANUBE)
  storeId              String?
  checkoutId           String
  token                String?
  contactName          String?
  contactEmail         String?
  contactPhone         String?
  abandonedCheckoutUrl String?
  subtotal             Decimal?  @db.Decimal(10, 2)
  totalAmount          Decimal?  @db.Decimal(10, 2)
  currency             String?
  gateway              String?
  shipping             String?
  shippingPickupType   String?
  shippingAddress      String?
  shippingCity         String?
  shippingProvince     String?
  shippingZipcode      String?
  status               String    @default("NEW")
  contactedAt          DateTime?
  recoveredAt          DateTime?
  lastMessageSentAt    DateTime?
  rawPayload           Json?
  products             Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  checkoutCreatedAt    DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider, checkoutId])
  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, contactPhone])
  @@index([workspaceId, storeId, checkoutCreatedAt])
  @@index([workspaceId, storeId, updatedAt])
}

model CustomerProfile {
  id                        String    @id @default(cuid())
  workspaceId               String
  provider                  CommerceProvider @default(TIENDANUBE)
  storeId                   String
  externalCustomerId        String?
  displayName               String?
  email                     String?
  normalizedEmail           String?
  phone                     String?
  normalizedPhone           String?
  identification            String?
  note                      String?
  acceptsMarketing          Boolean?
  acceptsMarketingUpdatedAt DateTime?
  defaultAddress            Json?
  addresses                 Json?
  billingAddress            String?
  billingNumber             String?
  billingFloor              String?
  billingLocality           String?
  billingZipcode            String?
  billingCity               String?
  billingProvince           String?
  billingCountry            String?
  billingPhone              String?
  orderCount                Int       @default(0)
  paidOrderCount            Int       @default(0)
  distinctProductsCount     Int       @default(0)
  totalUnitsPurchased       Int       @default(0)
  totalSpent                Decimal?  @db.Decimal(12, 2)
  currency                  String?
  firstOrderAt              DateTime?
  lastOrderAt               DateTime?
  lastOrderId               String?
  lastOrderNumber           String?
  lastPaymentStatus         String?
  lastShippingStatus        String?
  productSummary            Json?
  rawCustomerPayload        Json?
  rawLastOrderPayload       Json?
  syncedAt                  DateTime  @default(now())
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  orders     CustomerOrder[]
  orderItems CustomerOrderItem[]

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider, externalCustomerId])
  @@unique([workspaceId, normalizedEmail])
  @@unique([workspaceId, normalizedPhone])
  @@index([workspaceId, storeId, lastOrderAt])
  @@index([workspaceId, storeId, firstOrderAt])
  @@index([workspaceId, storeId, totalSpent])
  @@index([workspaceId, storeId, lastOrderNumber])
  @@index([workspaceId, storeId, orderCount])
  @@index([workspaceId, storeId, normalizedPhone])
  @@index([workspaceId, storeId, normalizedEmail])
}

model CustomerOrder {
  id                    String    @id @default(cuid())
  workspaceId           String
  provider              CommerceProvider @default(TIENDANUBE)
  customerProfileId     String
  storeId               String
  orderId               String
  orderNumber           String?
  token                 String?
  contactName           String?
  contactEmail          String?
  normalizedEmail       String?
  contactPhone          String?
  normalizedPhone       String?
  contactIdentification String?
  status                String?
  paymentStatus         String?
  shippingStatus        String?
  subtotal              Decimal?  @db.Decimal(12, 2)
  totalAmount           Decimal?  @db.Decimal(12, 2)
  currency              String?
  gateway               String?
  gatewayId             String?
  gatewayName           String?
  gatewayLink           String?
  products              Json?
  rawPayload            Json?
  orderCreatedAt        DateTime?
  orderUpdatedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customerProfile CustomerProfile     @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  items           CustomerOrderItem[]

  @@unique([workspaceId, provider, orderId])
  @@index([customerProfileId, orderCreatedAt])
  @@index([workspaceId, storeId, orderCreatedAt])
  @@index([workspaceId, normalizedEmail])
  @@index([workspaceId, normalizedPhone])
  @@index([workspaceId, storeId, orderNumber])
  @@index([workspaceId, storeId, paymentStatus, orderCreatedAt])
  @@index([workspaceId, storeId, shippingStatus, orderCreatedAt])
}

model CustomerOrderItem {
  id                String    @id @default(cuid())
  workspaceId       String
  provider          CommerceProvider @default(TIENDANUBE)
  customerOrderId   String
  customerProfileId String
  storeId           String
  orderId           String
  orderNumber       String?
  productId         String?
  variantId         String?
  lineItemId        String?
  sku               String?
  barcode           String?
  name              String
  normalizedName    String
  variantName       String?
  quantity          Int       @default(1)
  unitPrice         Decimal?  @db.Decimal(12, 2)
  lineTotal         Decimal?  @db.Decimal(12, 2)
  imageUrl          String?
  rawPayload        Json?
  orderCreatedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customerOrder   CustomerOrder   @relation(fields: [customerOrderId], references: [id], onDelete: Cascade)
  customerProfile CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([customerProfileId, orderCreatedAt])
  @@index([workspaceId, storeId, normalizedName])
  @@index([workspaceId, storeId, productId])
  @@index([workspaceId, storeId, orderNumber])
  @@index([workspaceId, orderId])
}

model CustomerSyncLog {
  id               String    @id @default(cuid())
  workspaceId      String
  provider         CommerceProvider @default(TIENDANUBE)
  storeId          String?
  status           String
  fullSync         Boolean   @default(true)
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  pagesFetched     Int       @default(0)
  ordersFetched    Int       @default(0)
  ordersUpserted   Int       @default(0)
  customersTouched Int       @default(0)
  message          String?
  createdAt        DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, storeId, status, startedAt])
}

model EnboxShipment {
  id                 String   @id @default(cuid())
  workspaceId        String
  didEnvio           String
  didCliente         String?
  storeId            String?
  orderId            String?
  orderNumber        String?
  shipmentNumber     String?
  packId             String?
  trackingNumber     String?
  trackingToken      String?
  trackingUrl        String?
  shippingStatus     String?
  shippingStatusCode String?
  recipientName      String?
  recipientPhone     String?
  recipientEmail     String?
  postalCode         String?
  addressLine        String?
  shippingMethod     String?
  source             String?
  rawSummary         Json?
  rawPayload         Json?
  discoveredAt       DateTime @default(now())
  lastSyncedAt       DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, didEnvio])
  @@index([workspaceId, orderNumber])
  @@index([workspaceId, shipmentNumber])
  @@index([workspaceId, packId])
  @@index([workspaceId, trackingNumber])
  @@index([workspaceId, storeId, orderNumber])
  @@index([workspaceId, lastSyncedAt])
}

model EnboxSyncLog {
  id               String   @id @default(cuid())
  workspaceId      String
  status           String
  mode             String
  startedAt        DateTime @default(now())
  finishedAt       DateTime?
  shipmentsChecked Int      @default(0)
  shipmentsUpserted Int     @default(0)
  ordersScanned    Int      @default(0)
  ordersMatched    Int      @default(0)
  message          String?
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, startedAt])
}

model WhatsAppTemplate {
  id              String    @id @default(cuid())
  workspaceId     String
  wabaId          String
  metaTemplateId  String?
  name            String
  language        String
  category        String
  status          String
  qualityScore    String?
  headerFormat    String?
  parameterFormat String?
  previewText     String?
  rejectedReason  String?
  disabledReason  String?
  lastSyncedAt    DateTime?
  deletedAt       DateTime?
  rawPayload      Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, wabaId, name, language])
  @@unique([workspaceId, metaTemplateId])
  @@index([workspaceId, name])
  @@index([workspaceId, status])
  @@index([workspaceId, category])
}

model TemplateSyncLog {
  id            String    @id @default(cuid())
  workspaceId   String
  status        String
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  fetchedCount  Int       @default(0)
  upsertedCount Int       @default(0)
  errorCount    Int       @default(0)
  message       String?
  rawPayload    Json?
  createdAt     DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startedAt])
}

model Campaign {
  id                  String         @id @default(cuid())
  workspaceId         String
  name                String
  templateLocalId     String?
  templateMetaId      String?
  templateName        String
  templateLanguage    String
  templateCategory    String?
  status              CampaignStatus @default(DRAFT)
  audienceSource      String?
  notes               String?
  launchedByUserId    String?
  totalRecipients     Int            @default(0)
  pendingRecipients   Int            @default(0)
  sentRecipients      Int            @default(0)
  deliveredRecipients Int            @default(0)
  readRecipients      Int            @default(0)
  failedRecipients    Int            @default(0)
  skippedRecipients   Int            @default(0)
  defaultComponents   Json?
  previewText         String?
  lastError           String?
  startedAt           DateTime?
  finishedAt          DateTime?
  dispatchLockedAt    DateTime?
  dispatchLockId      String?
  rawPayload          Json?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipients CampaignRecipient[]
  conversions CampaignConversion[]

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, dispatchLockedAt])
}

model CampaignRecipient {
  id                   String                  @id @default(cuid())
  workspaceId          String
  campaignId           String
  phone                String
  waId                 String?
  contactName          String?
  contactId            String?
  conversationId       String?
  externalKey          String?
  variables            Json?
  renderedComponents   Json?
  renderedPreviewText  String?
  status               CampaignRecipientStatus @default(PENDING)
  waMessageId          String?
  errorCode            String?
  errorSubcode         String?
  errorMessage         String?
  pricingCategory      String?
  conversationCategory String?
  billable             Boolean?
  rawPayload           Json?
  sentAt               DateTime?
  deliveredAt          DateTime?
  readAt               DateTime?
  failedAt             DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  conversions CampaignConversion[]

  @@unique([workspaceId, waMessageId])
  @@index([workspaceId, campaignId, status])
  @@index([workspaceId, phone])
}

model CampaignConversion {
  id                     String   @id @default(cuid())
  workspaceId            String
  campaignId             String
  recipientId            String?
  conversionKey          String
  source                 String
  confidence             String
  orderId                String?
  orderNumber            String?
  checkoutId             String?
  cartId                 String?
  contactName            String?
  phone                  String?
  email                  String?
  amount                 Decimal? @db.Decimal(12, 2)
  currency               String?
  paymentStatus          String?
  sentAt                 DateTime?
  convertedAt            DateTime
  attributionWindowHours Int      @default(168)
  matchReason            String?
  rawPayload             Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recipient CampaignRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, conversionKey])
  @@index([workspaceId, campaignId, source])
  @@index([workspaceId, recipientId])
  @@index([workspaceId, orderId])
  @@index([workspaceId, checkoutId])
  @@index([workspaceId, convertedAt])
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum CommerceProvider {
  TIENDANUBE
  SHOPIFY
}

enum LogisticsProvider {
  ENBOX
}

enum ConnectionStatus {
  ACTIVE
  DISABLED
  ERROR
  PENDING
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum ConversationQueue {
  AUTO
  HUMAN
  PAYMENT_REVIEW
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum CampaignStatus {
  DRAFT
  QUEUED
  RUNNING
  FINISHED
  PARTIAL
  FAILED
  CANCELED
}

enum CampaignRecipientStatus {
  PENDING
  SENT
