<aside class="admin-sidebar" id="adminSidebar">
	<div class="admin-sidebar-top">
		<button class="admin-collapse-btn" type="button" id="sidebarToggle" title="Expandir / contraer">
			☰
		</button>

		<div class="admin-brand">
			<div class="admin-brand-mark">L</div>

			<div class="admin-brand-copy">
				<div class="eyebrow">Lummine Console</div>
				<h1><%= appName || 'Lummine' %></h1>
				<p class="muted">Ventas conversacionales</p>
			</div>
		</div>
	</div>

	<nav class="admin-menu">
		<div class="admin-menu-group">
			<div class="admin-menu-label">Bandejas</div>

			<a href="/dashboard/inbox?queue=AUTO" class="admin-menu-link <%= page === 'inbox' && currentQueue === 'AUTO' ? 'active' : '' %>">
				<span class="admin-menu-icon">•</span>
				<span class="admin-menu-text">Auto</span>
			</a>

			<a href="/dashboard/inbox?queue=HUMAN" class="admin-menu-link <%= page === 'inbox' && currentQueue === 'HUMAN' ? 'active' : '' %>">
				<span class="admin-menu-icon">•</span>
				<span class="admin-menu-text">Atención humana</span>
			</a>

			<a href="/dashboard/inbox?queue=PAYMENT_REVIEW" class="admin-menu-link <%= page === 'inbox' && currentQueue === 'PAYMENT_REVIEW' ? 'active' : '' %>">
				<span class="admin-menu-icon">•</span>
				<span class="admin-menu-text">Comprobantes</span>
			</a>
		</div>

		<div class="admin-menu-group">
			<div class="admin-menu-label">Gestión</div>

			<a href="/dashboard/catalog" class="admin-menu-link <%= page === 'catalog' ? 'active' : '' %>">
				<span class="admin-menu-icon">•</span>
				<span class="admin-menu-text">Catálogo</span>
			</a>

			<a href="/dashboard/campaigns" class="admin-menu-link <%= page === 'campaigns' ? 'active' : '' %>">
				<span class="admin-menu-icon">•</span>
				<span class="admin-menu-text">Campañas</span>
			</a>


			<a href="/dashboard/abandoned-carts" class="admin-menu-link <%= page === 'abandoned-carts' ? 'active' : '' %>">
				<span class="admin-menu-icon">•</span>
				<span class="admin-menu-text">Carritos abandonados</span>
			</a>
		</div>
	</nav>

	<div class="admin-sidebar-bottom">
		<form method="POST" action="/logout">
			<button class="btn btn-ghost admin-logout-btn" type="submit">
				<span>Salir</span>
			</button>
		</form>
	</div>
</aside>