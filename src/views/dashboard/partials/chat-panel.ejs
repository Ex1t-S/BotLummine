<section class="wa-chat-column">
	<% if (!selectedContact) { %>
		<div class="wa-chat-empty">
			<div class="wa-empty-mark">L</div>
			<h2>Centro de conversaciones</h2>
			<p class="muted">Seleccioná un cliente para ver el historial, responder manualmente o seguir la conversación asistida.</p>
		</div>
	<% } else { %>
		<header class="wa-chat-topbar">
			<div class="wa-chat-user">
				<div class="avatar avatar-lg" style="<%= selectedContact.avatar.style %>"><%= selectedContact.avatar.initials %></div>

				<div class="wa-chat-user-copy">
					<h2><%= selectedContact.displayName %></h2>
					<div class="muted"><%= selectedContact.phoneDisplay || '' %></div>
				</div>
			</div>

			<div class="wa-chat-actions">
				<div class="chat-status-chip">Asistente activo</div>
				<button class="chat-action-btn" type="button" disabled>Cliente</button>
				<button class="chat-action-btn" type="button" disabled>Pedido</button>
				<button class="chat-action-btn" type="button" disabled>Transferir</button>
			</div>
		</header>

		<div class="wa-chat-body wa-scroll">
			<% if (!selectedContact.messages.length) { %>
				<div class="empty-list muted">Todavía no hay mensajes.</div>
			<% } %>

			<% selectedContact.messages.forEach((msg) => { %>
				<div class="wa-msg-row <%= msg.direction === 'OUTBOUND' ? 'out' : 'in' %>">
					<div class="wa-msg-bubble <%= msg.direction === 'OUTBOUND' ? 'out' : 'in' %>">
						<div class="wa-msg-text"><%= msg.body %></div>

						<div class="wa-msg-meta">
							<span><%= msg.createdAtLabel %></span>
							<% if (msg.tokenTotal) { %>
								<span>· <%= msg.tokenTotal %> tok</span>
							<% } %>
						</div>
					</div>
				</div>
			<% }) %>
		</div>

		<footer class="wa-chat-composer">
			<form method="POST" action="/dashboard/conversations/<%= selectedContact.conversationId %>/reply" class="wa-composer-form">
				<div class="wa-input-shell">
					<textarea name="body" rows="1" placeholder="Escribí un mensaje para el cliente" required></textarea>
				</div>

				<button class="wa-send-circle" type="submit" title="Enviar">
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path d="M4 12 19 4l-4.5 16-2.8-5.2L4 12Z" fill="currentColor"/>
					</svg>
					<span>Enviar</span>
				</button>
			</form>
		</footer>
	<% } %>
</section>
