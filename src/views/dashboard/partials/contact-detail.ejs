<section class="card-soft inbox-detail-panel">
	<% if (!selectedContact) { %>
		<div class="empty-list muted">Sin detalle.</div>
	<% } else { %>
		<h3 style="margin-top:0;">Detalle</h3>

		<div class="detail-block">
			<div class="muted tiny">Nombre</div>
			<div><%= selectedContact.displayName %></div>
		</div>

		<div class="detail-block">
			<div class="muted tiny">Teléfono</div>
			<div><%= selectedContact.phoneDisplay || 'No informado' %></div>
		</div>

		<div class="detail-block">
			<div class="muted tiny">Último mensaje</div>
			<div><%= selectedContact.preview || 'Sin actividad' %></div>
		</div>

		<div class="detail-block">
			<div class="muted tiny">IA</div>
			<div><%= selectedContact.aiEnabled ? 'Activada' : 'Desactivada' %></div>
		</div>

		<div class="detail-block">
			<div class="muted tiny">Última actividad</div>
			<div><%= selectedContact.lastMessageLabel || 'Sin datos' %></div>
		</div>
	<% } %>
</section>