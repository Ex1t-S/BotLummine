<section class="wa-contact-column">
	<div class="wa-contact-header">
		<div>
			<h3>Conversaciones</h3>
			<div class="muted tiny"><%= Array.isArray(contacts) ? contacts.length : 0 %> chats</div>
		</div>
	</div>

	<div class="wa-contact-search">
		<input type="text" placeholder="Buscar conversaciones o clientes" disabled />
	</div>

	<div class="wa-contact-list wa-scroll">
		<% if (!contacts || !contacts.length) { %>
			<div class="empty-list muted">No hay chats en esta bandeja.</div>
		<% } %>

		<% (contacts || []).forEach((contact) => { %>
			<a
				class="wa-contact-item <%= selectedContact && selectedContact.conversationId === contact.conversationId ? 'active' : '' %>"
				href="/dashboard/conversations/<%= contact.conversationId %>?queue=<%= currentQueue %>"
			>
				<div class="avatar wa-contact-avatar" style="<%= contact.avatar.style %>"><%= contact.avatar.initials %></div>

				<div class="wa-contact-copy">
					<div class="wa-contact-top">
						<strong><%= contact.displayName %></strong>
						<span class="muted tiny"><%= contact.lastMessageTime || '' %></span>
					</div>

					<div class="wa-contact-bottom">
						<span class="wa-contact-preview"><%= contact.preview || 'Sin mensajes aún' %></span>
					</div>

					<div class="wa-contact-meta-row">
						<span class="badge badge-<%= contact.queueBadgeClass %>"><%= contact.queueLabel %></span>
						<% if (contact.phoneDisplay) { %>
							<span class="muted tiny"><%= contact.phoneDisplay %></span>
						<% } %>
					</div>
				</div>
			</a>
		<% }) %>
	</div>
</section>