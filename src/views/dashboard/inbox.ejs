<%- include('../partials/header', { title, appName }) %>

<div class="admin-shell" id="adminShell">
	<%- include('./partials/sidebar', { appName, page, currentQueue }) %>

	<section class="admin-content">
		<div class="inbox-toolbar">
			<a href="/dashboard/inbox?queue=AUTO" class="queue-tab <%= currentQueue === 'AUTO' ? 'active' : '' %>">
				<span>Auto</span>
				<strong><%= counts?.AUTO || 0 %></strong>
			</a>

			<a href="/dashboard/inbox?queue=HUMAN" class="queue-tab <%= currentQueue === 'HUMAN' ? 'active' : '' %>">
				<span>Atención humana</span>
				<strong><%= counts?.HUMAN || 0 %></strong>
			</a>

			<a href="/dashboard/inbox?queue=PAYMENT_REVIEW" class="queue-tab <%= currentQueue === 'PAYMENT_REVIEW' ? 'active' : '' %>">
				<span>Comprobantes</span>
				<strong><%= counts?.PAYMENT_REVIEW || 0 %></strong>
			</a>
		</div>

		<div class="wa-chat-app">
			<%- include('./partials/contact-list', { contacts, selectedContact, currentQueue }) %>
			<%- include('./partials/chat-panel', { selectedContact, currentQueue }) %>
		</div>
	</section>
</div>

<script src="/js/dashboard.js"></script>

<%- include('../partials/footer') %>