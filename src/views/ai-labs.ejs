<%- include('partials/header', { title, appName }) %>

<div class="wa-shell">
  <aside class="wa-sidebar ai-sidebar">
    <div class="wa-brand">
      <div>
        <div class="eyebrow">Panel</div>
        <h1><%= appName %></h1>
        <p class="muted">Pruebas, prompts y tono de la IA.</p>
      </div>

      <a href="/dashboard" class="btn btn-ghost btn-icon">Volver a chats</a>
    </div>

    <nav class="wa-nav card-soft">
      <a href="/dashboard" class="wa-nav-link <%= page === 'chats' ? 'active' : '' %>">Chats</a>
      <a href="/dashboard/ai-lab" class="wa-nav-link <%= page === 'ai-lab' ? 'active' : '' %>">IA Lab</a>
    </nav>

    <div class="card-soft ai-side-copy">
      <h3>Qué probar acá</h3>
      <ul class="feature-list">
        <li>Saludo inicial y presentación.</li>
        <li>Tono más humano y menos robótico.</li>
        <li>Cuándo mencionar promos y cuándo no.</li>
        <li>Respuesta breve para talle, stock, envío y pagos.</li>
      </ul>
    </div>
  </aside>

  <main class="wa-main ai-main">
    <section class="card-soft ai-lab-hero">
      <div>
        <div class="eyebrow">IA Lab</div>
        <h2>Probá respuestas sin tocar el chat real</h2>
        <p class="muted">Acá ajustás tono, copy y contexto. El envío manual queda dentro del chat, como WhatsApp.</p>
      </div>
    </section>

    <section class="ai-grid">
      <div class="card-soft">
        <h3>Probar proveedor de IA</h3>

        <form method="POST" action="/dashboard/ai-lab/test" class="form">
          <label>
            <span>Mensaje de prueba</span>
            <textarea name="prompt" rows="6" placeholder="Hola, me dijeron que soy talle XL. ¿Cómo sé si el body me va a ir bien?"></textarea>
          </label>

          <button class="btn btn-primary" type="submit">Generar respuesta</button>
        </form>
      </div>

      <div class="card-soft">
        <h3>Respuesta</h3>

        <% if (aiTestResult) { %>
          <div class="result-box ai-result <%= aiTestResult.ok ? '' : 'error' %>">
            <p><%= aiTestResult.text %></p>

            <% if (aiTestResult.usage) { %>
              <small class="muted">
                Tokens in: <%= aiTestResult.usage.inputTokens ?? '-' %>
                · out: <%= aiTestResult.usage.outputTokens ?? '-' %>
                · total: <%= aiTestResult.usage.totalTokens ?? '-' %>
              </small>
            <% } %>
          </div>
        <% } else { %>
          <div class="result-box placeholder-box">
            <p class="muted">Todavía no corriste ninguna prueba.</p>
          </div>
        <% } %>
      </div>
    </section>
  </main>
</div>

<%- include('partials/footer') %>