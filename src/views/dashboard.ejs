<%- include('partials/header', { title, appName }) %>

<%
	const safeThreads = Array.isArray(threads) ? threads : [];
	const safeSelectedThread = selectedThread || null;

	function safeTime(value) {
		try {
			return value
				? new Date(value).toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' })
				: '';
		} catch {
			return '';
		}
	}

	function safeDateTime(value) {
		try {
			return value ? new Date(value).toLocaleString('es-AR') : '';
		} catch {
			return '';
		}
	}
%>

<div class="wa-shell">
	<aside class="wa-sidebar">
		<div class="wa-brand">
			<div>
				<div class="eyebrow">Panel</div>
				<h1><%= appName || 'Panel' %></h1>
				<p class="muted">Chats activos y atención manual.</p>
			</div>

			<form method="POST" action="/logout">
				<button class="btn btn-ghost btn-icon" type="submit">Salir</button>
			</form>
		</div>

		<nav class="wa-nav card-soft">
			<a href="/dashboard" class="wa-nav-link <%= page === 'chats' ? 'active' : '' %>">Chats</a>
			<a href="/dashboard/ai-lab" class="wa-nav-link <%= page === 'ai-lab' ? 'active' : '' %>">IA Lab</a>
		</nav>

		<div class="wa-conversations card-soft">
			<div class="row-between wa-list-head">
				<h3>Conversaciones</h3>
				<span class="badge"><%= safeThreads.length %></span>
			</div>

			<div class="conversation-list wa-scroll">
				<% if (!safeThreads.length) { %>
					<div class="empty-list muted">Todavía no hay chats cargados.</div>
				<% } %>

				<% safeThreads.forEach((thread) => { %>
					<%
						const isActive = safeSelectedThread && safeSelectedThread.key === thread.key;
						const avatarStyle = thread?.avatar?.style || '';
						const avatarInitials = thread?.avatar?.initials || '?';
						const displayName = thread?.displayName || 'Sin nombre';
						const phoneDisplay = thread?.phoneDisplay || '';
						const preview = thread?.preview || '';
						const latestConversationId = thread?.latestConversationId || '';
						const aiEnabled = !!thread?.aiEnabled;
					%>

					<a
						class="conversation-item <%= isActive ? 'active' : '' %>"
						href="/dashboard/conversations/<%= latestConversationId %>"
					>
						<div class="avatar" style="<%= avatarStyle %>"><%= avatarInitials %></div>

						<div class="conversation-copy">
							<div class="row-between conversation-top">
								<strong><%= displayName %></strong>
								<span class="muted tiny"><%= safeTime(thread?.lastMessageAt) %></span>
							</div>

							<div class="muted tiny"><%= phoneDisplay %></div>
							<div class="conversation-preview"><%= preview %></div>
						</div>

						<div class="mini-pill <%= aiEnabled ? 'ok' : 'off' %>">
							IA <%= aiEnabled ? 'ON' : 'OFF' %>
						</div>
					</a>
				<% }) %>
			</div>
		</div>

		<div class="card-soft test-box">
			<h3>Nuevo chat de prueba</h3>
			<p class="muted">Simulá un mensaje entrante y cae directo al panel.</p>

			<form method="POST" action="/dashboard/simulate-inbound" class="form compact">
				<label>
					<span>Nombre</span>
					<input type="text" name="name" placeholder="German" />
				</label>

				<label>
					<span>WhatsApp</span>
					<input type="text" name="waId" placeholder="54292315562286" />
				</label>

				<label>
					<span>Mensaje</span>
					<textarea name="body" rows="3" placeholder="Hola, me dijeron que soy talle XL"></textarea>
				</label>

				<button class="btn btn-primary" type="submit">Simular mensaje</button>
			</form>
		</div>
	</aside>

	<main class="wa-main">
		<% if (!safeSelectedThread) { %>
			<section class="wa-empty">
				<div class="empty-card">
					<h2>No hay chats para mostrar</h2>
					<p class="muted">Creá un mensaje de prueba o conectá WhatsApp para ver conversaciones reales.</p>
				</div>
			</section>
		<% } else { %>
			<%
				const selectedAvatarStyle = safeSelectedThread?.avatar?.style || '';
				const selectedAvatarInitials = safeSelectedThread?.avatar?.initials || '?';
				const selectedDisplayName = safeSelectedThread?.displayName || 'Sin nombre';
				const selectedPhoneDisplay = safeSelectedThread?.phoneDisplay || '';
				const selectedMessages = Array.isArray(safeSelectedThread?.messages) ? safeSelectedThread.messages : [];
				const selectedAiEnabled = !!safeSelectedThread?.aiEnabled;
				const selectedConversationId = safeSelectedThread?.latestConversationId || '';
			%>

			<section class="wa-chat-shell">
				<header class="wa-chat-header">
					<div class="wa-chat-user">
						<div class="avatar avatar-lg" style="<%= selectedAvatarStyle %>"><%= selectedAvatarInitials %></div>

						<div>
							<h2><%= selectedDisplayName %></h2>
							<div class="muted"><%= selectedPhoneDisplay %></div>

							<% if (safeSelectedThread?.lastSummary) { %>
								<div class="muted tiny summary-line"><%= safeSelectedThread.lastSummary %></div>
							<% } %>
						</div>
					</div>

					<form method="POST" action="/dashboard/conversations/<%= selectedConversationId %>/toggle-ai">
						<button class="btn <%= selectedAiEnabled ? 'btn-secondary' : 'btn-primary' %>" type="submit">
							IA <%= selectedAiEnabled ? 'activada' : 'desactivada' %>
						</button>
					</form>
				</header>

				<div class="wa-chat-stage">
					<div class="wa-chat-scroll wa-scroll">
						<% if (!selectedMessages.length) { %>
							<div class="empty-list muted">Todavía no hay mensajes en esta conversación.</div>
						<% } %>

						<% selectedMessages.forEach((msg) => { %>
							<%
								const isOutbound = msg?.direction === 'OUTBOUND';
								const bubbleClass = isOutbound ? 'outbound' : 'inbound';
								const msgBody = msg?.body || '';
								const msgCreatedAt = safeDateTime(msg?.createdAt);
								const tokenTotal = msg?.tokenTotal;
							%>

							<div class="bubble-row <%= bubbleClass %>">
								<% if (!isOutbound) { %>
									<div class="avatar avatar-sm" style="<%= selectedAvatarStyle %>"><%= selectedAvatarInitials %></div>
								<% } %>

								<div class="message-bubble <%= bubbleClass %>">
									<div class="message-body"><%= msgBody %></div>

									<div class="message-meta">
										<span><%= msgCreatedAt %></span>
										<% if (tokenTotal) { %>
											<span>· <%= tokenTotal %> tok</span>
										<% } %>
									</div>
								</div>
							</div>
						<% }) %>
					</div>
				</div>

				<footer class="wa-composer-wrap">
					<form
						method="POST"
						action="/dashboard/conversations/<%= selectedConversationId %>/reply"
						class="wa-composer"
					>
						<textarea name="body" rows="1" placeholder="Escribí un mensaje manual..." required></textarea>
						<button class="btn btn-primary" type="submit">Enviar</button>
					</form>
				</footer>
			</section>
		<% } %>
	</main>
</div>

<%- include('partials/footer') %>