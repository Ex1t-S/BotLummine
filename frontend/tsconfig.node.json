{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2023"],
		"module": "ESNext",
		"skipLibCheck": true,
		"allowJs": true,
		"checkJs": false,
		"moduleResolution": "Bundler",
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"noEmit": true,
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["vite.config.js"]
}
